# ============================================================================
# claude-brain .gitignore
# SECURITY: Prevents personal data from being pushed to public GitHub repo
# ============================================================================

# --- PERSONAL DATA (NEVER COMMIT) ---

# Config file (contains personal paths, generated by brain-setup.py)
config.yaml

# Filled questionnaire (personal data — any filename variation)
brain-questionnaire.txt
*QUESTIONNAIRE*

# --- INTERNAL GOVERNANCE DOCS (personal paths, build history) ---

# Master plan with hardcoded paths and personal references
CLAUDE_BRAIN_MVP_PLAN.txt

# Build tracker with personal paths and session notes
PROJECT_TRACKER.md

# Folder schema with hardcoded paths
FOLDER_SCHEMA.md

# Dependencies with personal account references
DEPENDENCIES.md

# Database connection info with hardcoded paths
DATABASE_INFO.txt

# Session prompts and workflow docs (personal)
NEXT_SESSION_START_PROMPT.txt
DUAL_SESSION_GUIDE.txt
SESSION_PROMPTS_REFERENCE.md
SAVE_EXISTING_SESSIONS.md
CLAUDE_AI_IMPORT_PROCESS.md
dolan_status.md

# Root CLAUDE.md (personal project instructions, generated by brain-setup)
CLAUDE.md

# Project CLAUDE.md files (personalized per user, generated by brain-setup)
johnny-goods/CLAUDE.md
johnny-goods-assistant/CLAUDE.md
general/CLAUDE.md
job-search/CLAUDE.md
leg-therapy/CLAUDE.md
other/CLAUDE.md

# Database (contains all personal conversations)
*.db
*.db-journal
*.db-wal
*.db-shm

# ChromaDB vector store (personal embeddings)
chromadb/

# Raw session transcripts (personal conversations)
jsonl-archive/

# Claude.ai exports (personal conversations)
imports/*.json
# Keep imports/completed/ structure but not contents
imports/completed/*.json

# Session logs
logs/

# Database backups
db-backup/

# Session file snapshots (personal content)
**/chat-files/
**/history/

# Legacy Windows-era folder (personal files, not a project)
mike-brain/

# --- PROJECT-SPECIFIC CONTENT (PERSONAL) ---

# Manuscript files (copyrighted content)
johnny-goods/chapters/
johnny-goods/source/
johnny-goods-assistant/chapters/
johnny-goods-assistant/source/

# Project archives (old CLAUDE.md versions, master plans, personal notes)
johnny-goods/archive/
johnny-goods-assistant/archive/
general/archives/

# Project start prompts (personal workflow)
johnny-goods/START_PROMPTS.txt
johnny-goods-assistant/START_PROMPTS.txt

# Project-specific scripts (personal, not part of brain core)
johnny-goods/scripts/
johnny-goods-assistant/scripts/

# Project output directories
johnny-goods/output/
johnny-goods-assistant/output/

# --- BUILD/RUNTIME ARTIFACTS ---

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# --- EDITOR/OS JUNK ---

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/

# OS files
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.kate-swp

# --- CLAUDE CODE INTERNAL ---

# Claude Code auto-generated (lives in ~/.claude/, not here)
.claude/

# --- KEEP THESE (explicit overrides) ---

# Keep folder structure markers
!imports/completed/.gitkeep
!db-backup/.gitkeep
!logs/.gitkeep
chat-logs/
