################################################################################
# claude-brain Configuration File
# config.yaml
################################################################################
#
# This is the central configuration for claude-brain, a persistent memory
# system for Claude Code using SQLite and MCP.
#
# FIRST-TIME SETUP:
#   Run: brain-setup
#   The setup script checks dependencies, creates all folders, and
#   generates this config file interactively. You should not need to
#   edit this file manually unless you are changing settings later.
#
# FOR OPEN SOURCE USERS:
#   This file is generated by brain-setup with YOUR values.
#   The repository includes config.yaml.example with placeholder values.
#   Your real config.yaml is in .gitignore and never uploaded to GitHub.
#
# DOCUMENTATION:
#   Full system documentation: README.md
#   Architecture and decisions: PROJECT-PLAN.md
#   Import instructions:        imports/HOWTO.md
#
################################################################################

# ==============================================================================
# STORAGE
# ==============================================================================
# claude-brain supports two storage modes:
#
# "synced" = Root folder lives inside a sync service (Dropbox, OneDrive,
#            Google Drive, or iCloud). Everything syncs between machines
#            automatically. The database file is stored separately on
#            local disk to prevent SQLite corruption from sync conflicts.
#
# "local"  = Root folder lives on local disk. Everything in one place.
#            Best for single-computer setups. Database lives inside the
#            root folder.
#
# The brain-setup script sets these values during first-time installation.
# You can change paths later, but you must move the actual files/folders
# to match.

storage:
  mode: "synced"                    # "synced" or "local"
  root_path: "~/Dropbox/claude-brain"    # Change to YOUR sync folder path
  # local_db_path is ONLY used when mode is "synced".
  # When mode is "local", the database lives at root_path/claude-brain.db
  local_db_path: "~/claude-brain-local/claude-brain.db"  # Change if needed

# ==============================================================================
# SYNC PROVIDER
# ==============================================================================
# Supported providers for v0.1.0: dropbox, onedrive, google-drive, icloud
# Set to "none" if storage mode is "local".
#
# The sync provider name is used for provider-specific optimizations.
# For example, Dropbox has a CLI that can check sync status before
# backing up the database. Other providers use file-size verification
# after backup to confirm the copy succeeded.
#
# If your provider is not listed, set it to "other" and claude-brain
# will use file-size verification (works with any provider).

sync_provider:
  name: "dropbox"                   # Your provider: dropbox, onedrive, google-drive, icloud, other, none                   # dropbox, onedrive, google-drive, icloud, other, none
  # Dropbox-only: check sync status via CLI before backup
  # Ignored for all other providers
  check_status_cli: true

# ==============================================================================
# DATABASE
# ==============================================================================
# The database path is determined by storage mode:
#   synced mode: uses storage.local_db_path (local disk, not synced)
#   local mode:  uses storage.root_path/claude-brain.db
#
# You do not set the database path here. It is derived from the storage
# section above.
#
# IMPORTANT: The database must NEVER live in a synced folder.
# SQLite databases corrupt when multiple sync clients write to them
# simultaneously. This is a hard technical limitation, not a preference.

database:
  # Write every Claude Code exchange to the database in real time.
  # write_exchange.py handles this automatically during sessions.
  write_every_response: true

  # Read priority order when Claude Code searches for information.
  # "database" = check brain first
  # "tools"    = use MCP tools
  # "web"      = search the internet
  read_priority:
    - database
    - tools
    - web

# ==============================================================================
# BACKUP
# ==============================================================================
# Database backups are stored in the db-backup/ folder inside the root.
# If using synced mode, backups sync to all machines automatically.
# Backups run after JSONL ingestion completes (during startup check
# or end-of-session sync).
#
# The backup process:
# 1. Copy database to db-backup/ with rotating filename
# 2. Verify the copy succeeded (file size match)
# 3. If Dropbox: optionally check sync status via CLI
# 4. If verification fails: retry once, then log error

backup:
  max_copies: 2                     # Rotating backup count (oldest deleted)
  verify_after_copy: true           # Compare file sizes after backup

# ==============================================================================
# PROJECTS
# ==============================================================================
# Each project maps a folder name to a database table prefix.
# The folder_name must match an actual folder inside the root.
# The prefix is used for all database tables for that project
# (e.g., jg_transcripts, jg_summaries).
#
# brain-setup creates these folders and stores the prefix mapping
# in the database for runtime lookup. If you add a project here,
# run brain-setup again or create the folder manually and the
# startup check will register the new prefix automatically.
#
# TO ADD A NEW PROJECT:
#   1. Add an entry below
#   2. Run: brain-setup (or create the folder + CLAUDE.md manually)
#   3. The startup check registers the prefix on next session
#   4. Tables are auto-created on first write
#
# NAMING:
#   folder_name: lowercase, hyphens (e.g., "johnny-goods")
#   prefix:      lowercase, underscores, 2-4 chars + _ (e.g., "jg_")
#   label:       human-readable name shown in brain-import picklist

projects:
  - folder_name: "my-project"
    prefix: "mp_"
    label: "My First Project"

  - folder_name: "general"
    prefix: "gen_"
    label: "General Conversations"

  - folder_name: "dev-tools"
    prefix: "dt_"
    label: "Development Tools"

  - folder_name: "side-project"
    prefix: "sp_"
    label: "Side Project"

  - folder_name: "personal"
    prefix: "per_"
    label: "Personal"

  - folder_name: "other"
    prefix: "oth_"
    label: "Uncategorized"

# ==============================================================================
# BRAIN PROFILE
# ==============================================================================
# brain_ tables store personal profile data (from questionnaire).
# These are NOT project-specific — they apply across ALL projects.
# Data is written only after Y/F/R verification by the user.

brain:
  prefix: "brain_"
  categories:
    - identity
    - family
    - professional
    - working-style
    - technical-setup
    - goals
    - preferences
    - lessons-learned
    - contacts

# ==============================================================================
# JSONL INGESTION
# ==============================================================================
# Claude Code automatically saves session logs as JSONL files.
# claude-brain ingests these files to capture any exchanges that
# write_exchange.py may have missed (e.g., if the terminal was
# closed without typing /exit).
#
# BEHAVIOR (not configurable — always on for reliability):
#   - Runs at the START of every session (blocking — must complete
#     before the user can work)
#   - Always deduplicates (skips records already in the database)
#   - Zero human intervention required
#   - Errors are logged and retried next session
#   - Also runs at end of session if /exit hook fires
#
# The startup check is the PRIMARY sync mechanism.
# The /exit hook is a SECONDARY convenience (makes backups current
# immediately, but if missed, startup catches everything).

jsonl:
  # Where Claude Code stores JSONL session logs.
  # This is the standard Claude Code location.
  source_path: "~/.claude/projects"

# ==============================================================================
# CLAUDE.AI IMPORTS
# ==============================================================================
# Conversations exported from claude.ai can be imported into the
# database via the brain-import command.
#
# PROCESS:
#   1. Export a conversation using AI Chat Exporter (Chrome extension)
#      Supported formats: TXT, JSON, Markdown
#   2. Save the exported file into the imports/ folder
#   3. Run: brain-import
#   4. Follow the prompts (project, date, topic, tags)
#   5. Successfully imported files move to imports/completed/
#
# The full import process is documented in imports/HOWTO.md
# and in the project plan.

imports:
  supported_formats:
    - "txt"
    - "json"
    - "md"

# ==============================================================================
# FILE VERSIONING
# ==============================================================================
# Files uploaded or modified during Claude Code sessions are stored
# in the chat-files/ subfolder of each project. Each session gets
# its own subfolder named with date, time, and a truncated session ID.
#
# Example: chat-files/2026-02-23_143022_d2a1d8c9/
#
# The session ID is the first 8 characters of the UUID that Claude
# Code assigns to each session (e.g., d2a1d8c9 from
# d2a1d8c9-bba6-4276-bb49-3e6ec5393822).

file_versioning:
  folder_pattern: "{date}_{time}_{session_id_short}"
  date_format: "YYYY-MM-DD"
  time_format: "HHMMSS"
  session_id_length: 8             # First 8 chars of UUID

# ==============================================================================
# VERIFICATION
# ==============================================================================
# When data is about to be written to brain_ tables (personal profile),
# the system generates a verification file FIRST. The user reviews
# each item and marks it before the data is committed to the database.
#
# FORMAT: [ ] followed by the fact. User marks:
#   [Y] = Yes, include in brain_ tables
#   [F] = Forget, do not include
#   [R] = Replace — fact is wrong. User writes correction after -->
#         Example: [R] User lives in Boston --> User lives in New York
#
# Verification files are saved to the verification/ folder.
# The full process is documented in the project plan.

verification:
  enabled: true

# ==============================================================================
# LOGGING
# ==============================================================================
# Logs are stored in the logs/ folder, organized by machine name.
# Machine name is auto-detected from the system hostname.
# Each machine gets its own subfolder so logs from different
# computers don't overwrite each other.
#
# Example: logs/fedora-laptop-1/sync_2026-02-23.log
#
# Log levels:
#   info    = normal operations (ingested 5 records, backup complete)
#   warning = something unexpected but not fatal (retry needed)
#   error   = something failed (ingestion failed, backup failed)

logging:
  level: "info"                     # info, warning, error

# ==============================================================================
# STARTUP
# ==============================================================================
# The startup check runs at the BEGINNING of every Claude Code session.
# It is BLOCKING — Claude Code does not process user messages until
# the startup check reports COMPLETE.
#
# What it does:
#   1. Verifies all folders exist (same checks as brain-doctor)
#   2. Finds unprocessed JSONL files (sessions not yet ingested)
#   3. Ingests new records into the database (deduplicates automatically)
#   4. Copies database backup to db-backup/
#   5. Reports status to the terminal
#
# This is the PRIMARY data sync mechanism. It guarantees the database
# is current regardless of whether the user typed /exit or closed
# the terminal window last session.

startup:
  run_on_session_start: true        # Do not disable this
  verify_folders: true              # Check folder structure integrity

# ==============================================================================
# SCRIPTS / COMMANDS
# ==============================================================================
# claude-brain provides these commands (aliases installed by brain-setup):
#
#   brain-setup    First-time installation. Creates folders, config,
#                  database, and aliases. Also re-run to add projects
#                  or fix a broken installation.
#
#   brain-import   Import exported claude.ai conversations. Interactive
#                  prompts walk you through project, date, topic, tags.
#
#   brain-tags     Manage tags. View, rename, merge, delete tags, or
#                  edit tags on a specific conversation.
#
#   brain-sync     Manually trigger JSONL ingestion + database backup.
#                  Normally runs automatically on startup and /exit.
#                  Use this if you want to force a sync mid-session.
#
#   brain-check    Manually run the startup check. Ingests unprocessed
#                  JSONL, backs up database, verifies folder structure.
#                  Same as what runs automatically on session start.
#
#   brain-status   Show database statistics: record counts per project,
#                  last sync time, database size, backup status.
#
#   brain-doctor   Full health check. Verifies all dependencies are
#                  installed, all folders exist, database is accessible,
#                  MCP server is registered, aliases are working.
#                  Run this when something seems broken.
#
# Script files live in the scripts/ folder. The aliases point to them.
# On Linux/Mac: aliases are added to ~/.bashrc or ~/.zshrc
# On Windows:   aliases are added as PowerShell functions or .bat files

scripts:
  # Script-to-command mapping (used by brain-setup to create aliases)
  commands:
    brain-setup:    "setup.py"
    brain-import:   "import_claude_ai.py"
    brain-tags:     "manage_tags.py"
    brain-sync:     "brain_sync.sh"
    brain-check:    "startup_check.py"
    brain-status:   "status.py"
    brain-doctor:   "doctor.py"

# ==============================================================================
# DEPENDENCIES
# ==============================================================================
# Required software for claude-brain v0.1.0.
# brain-setup checks these BEFORE creating any folders.
# brain-doctor re-checks these anytime.
#
# If a dependency is missing, the setup/doctor command tells you
# WHAT is missing and WHAT version is needed. How to install it
# depends on your operating system and package manager — the user
# is responsible for installing dependencies on their system.
#
# Minimum versions:
#   Python         3.10+
#   pip3           any
#   MCP SDK        any    (install via: pip3 install mcp)
#   Claude Code    2.0+
#   SQLite         3.35+  (included with Python, no separate install)
#   Node.js        18+    (required by Claude Code)

dependencies:
  python_min_version: "3.10"
  claude_code_min_version: "2.0"
  sqlite_min_version: "3.35"
  node_min_version: "18"

# ==============================================================================
# META
# ==============================================================================

meta:
  project_name: "claude-brain"
  version: "0.1.0"
  license: "MIT"
  github: "https://github.com/yourusername/claude-brain"
  author: "Your Name"
