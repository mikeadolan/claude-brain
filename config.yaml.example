################################################################################
# claude-brain Configuration File — EXAMPLE
# config.yaml.example
################################################################################
#
# This is the REFERENCE configuration for claude-brain, a persistent memory
# system for Claude Code using SQLite and MCP.
#
# HOW TO USE:
#   Option 1 (recommended): Run python3 scripts/brain-setup.py
#            The setup script generates config.yaml interactively.
#   Option 2 (manual): Copy this file to config.yaml and edit with your values.
#
# YOUR REAL config.yaml IS IN .gitignore — IT NEVER REACHES GITHUB.
#
# DOCUMENTATION:
#   Full system documentation: README.md
#   Import instructions:       imports/HOWTO.md
#
################################################################################

# ==============================================================================
# STORAGE
# ==============================================================================
# Two storage modes:
#
# "synced" = Root folder lives inside a sync service (Dropbox, OneDrive,
#            Google Drive, or iCloud). Everything syncs between machines
#            automatically. The database file is stored separately on
#            local disk to prevent SQLite corruption from sync conflicts.
#
# "local"  = Root folder lives on local disk. Everything in one place.
#            Best for single-computer setups. Database lives inside the
#            root folder.
#
# brain-setup sets these values during first-time installation.

storage:
  mode: "synced"                               # "synced" or "local"
  root_path: "~/Dropbox/claude-brain"          # Your root folder path
  # local_db_path is ONLY used when mode is "synced".
  # When mode is "local", the database lives at root_path/claude-brain.db
  local_db_path: "~/claude-brain-local/claude-brain.db"

# ==============================================================================
# DATABASE
# ==============================================================================
# The database path is derived from the storage section above.
# IMPORTANT: The database must NEVER live in a synced folder.
# SQLite databases corrupt when multiple sync clients write simultaneously.

database:
  write_every_response: true
  read_priority:
    - structured_tables    # decisions, facts, brain profile
    - raw_transcripts      # full-text search across all conversations
    - project_files        # text files in the project folder
    - tell_user_not_found  # "I don't have this information"

# ==============================================================================
# BACKUP
# ==============================================================================
# Rotating backups in db-backup/ inside root_path.
# Runs after JSONL ingestion (startup check and end-of-session).

backup:
  max_copies: 2                                # Rotating backup count
  verify_after_copy: true                      # Compare file sizes after backup

# ==============================================================================
# PROJECTS
# ==============================================================================
# Each project maps a folder name to a database prefix.
# The folder_name must match an actual folder inside the root.
#
# TO ADD A NEW PROJECT:
#   1. Add an entry below
#   2. Run: python3 scripts/brain-setup.py (or create folder + CLAUDE.md manually)
#   3. The startup check registers the prefix on next session
#
# NAMING:
#   folder_name: lowercase, hyphens only (e.g., "my-project")
#   prefix:      lowercase, 2-4 chars (e.g., "mp") — NO trailing underscore
#   label:       human-readable name shown in brain-import picklist

projects:
  - folder_name: "my-project"
    prefix: "mp"
    label: "My Project"

  - folder_name: "general"
    prefix: "gen"
    label: "General Conversations"

  - folder_name: "other"
    prefix: "oth"
    label: "Uncategorized"

# ==============================================================================
# BRAIN PROFILE
# ==============================================================================
# brain tables store personal profile data (from questionnaire).
# These are NOT project-specific — they apply across ALL projects.
# Data is written only after Y/F/R verification by the user.

brain:
  prefix: "brain"
  categories:
    - identity
    - family
    - professional
    - working-style
    - technical-setup
    - goals
    - preferences
    - lessons-learned
    - contacts
    - health

# ==============================================================================
# JSONL INGESTION
# ==============================================================================
# Claude Code saves session logs as JSONL files automatically.
# claude-brain ingests these at startup to capture any exchanges that
# write_exchange.py may have missed (e.g., terminal closed without /exit).
#
# BEHAVIOR (always on for reliability):
#   - Runs at the START of every session (blocking)
#   - Always deduplicates (skips records already in the database)
#   - Zero human intervention required

jsonl:
  source_paths:                                # List of directories to scan
    - "~/.claude/projects"                     # Standard Claude Code location
  ingest_subagents: true                       # Include subagent conversations
  ingest_tool_results: true                    # Include tool call outputs

# ==============================================================================
# JSONL PROJECT MAPPING
# ==============================================================================
# Maps folder names to project prefixes for JSONL ingestion.
# The ingest script checks these mappings to assign each session
# to the correct project. If no match found, defaults to "oth".
#
# Each key is a folder name (or path fragment) that appears in the
# JSONL file path or the cwd field inside the JSONL file.
# The value is the project prefix.
#
# ORDER MATTERS: longer/more-specific paths must come before shorter
# ones to prevent false matches (e.g., "my-project-docs" before
# "my-project").

jsonl_project_mapping:
  "my-project": "mp"
  "general": "gen"

# ==============================================================================
# LLM-POWERED SUMMARIES (optional)
# ==============================================================================
# If enabled, session summaries use an LLM API for richer, narrative
# summaries. Without a key, everything still works -- summaries just
# use simpler text extraction methods.
#
# Supported providers: "anthropic" or "openrouter"
# Typical cost: under $1/month (uses the smallest, cheapest model)
# The API key unlocks:
#   - Richer session summaries powered by AI (vs basic text extraction)
#   - Smarter fact and decision extraction from conversations
#   - Higher quality session notes for cross-session continuity

summary_llm:
  enabled: false                                 # Set to true + add API key
  provider: "openrouter"                         # "anthropic" or "openrouter"
  api_key: ""                                    # Your actual API key here
  model: "anthropic/claude-haiku-4.5"   # OpenRouter model ID
  # model: "claude-haiku-4-5-20251001"           # Use this for Anthropic API provider

# ==============================================================================
# SEMANTIC SEARCH
# ==============================================================================
# sentence-transformers + SQLite + numpy.
# Fully local. No cloud, no API keys, no cost.
# Embeddings stored in transcript_embeddings table in the main DB.
# Set enabled: false to skip embedding generation (saves ~200MB model download).

semantic_search:
  enabled: true
  model: "all-MiniLM-L6-v2"                   # 384-dim embeddings, ~80MB model

# ==============================================================================
# FILE VERSIONING
# ==============================================================================
# Files created/modified during sessions are copied to chat-files/
# inside each project folder. Each session gets its own subfolder.
# Example: chat-files/2026-02-23_143022_d2a1d8c9/

file_versioning:
  enabled: true
  folder_pattern: "{date}_{time}_{session_id_short}"
  date_format: "YYYY-MM-DD"
  time_format: "HHMMSS"
  session_id_length: 8                         # First 8 chars of UUID

# ==============================================================================
# LOGGING
# ==============================================================================
# Logs stored in logs/ folder, organized by machine hostname.
# Each machine gets its own subfolder so logs don't overwrite each other.
# Example: logs/fedora-laptop-1/sync_2026-02-23.log

logging:
  enabled: true
  level: "info"                                # info, warning, error

# ==============================================================================
# STARTUP
# ==============================================================================
# Runs at the BEGINNING of every Claude Code session. BLOCKING.
# Claude Code does not process user messages until complete.
#
# What it does:
#   1. Verifies all folders exist
#   2. Finds unprocessed JSONL files
#   3. Ingests new records (deduplicates automatically)
#   4. Copies database backup to db-backup/
#   5. Reports status

startup:
  run_on_session_start: true                   # Do not disable this
  blocking: true                               # Must complete before session
  verify_folders: true                         # Check folder structure integrity

# ==============================================================================
# SCRIPTS / COMMANDS
# ==============================================================================
# Script-to-command mapping. These are the core scripts that hooks
# and slash commands call. Paths are relative to the scripts/ folder.

scripts:
  commands:
    brain-check:    "startup_check.py"
    brain-sync:     "brain_sync.py"
    brain-status:   "status.py"

# ==============================================================================
# META
# ==============================================================================

meta:
  project_name: "claude-brain"
  version: "0.1.0"
  license: "MIT"
  github: "https://github.com/yourusername/claude-brain"
  author: "Your Name"
